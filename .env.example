# Werte die ins Flutter-Web-Bundle gebaut werden (sind im Browser sichtbar — by design public)
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=<generiert via scripts/generate-supabase-secrets.sh>
PROXY_URL=http://localhost:8083/api
# Optional: Override für RAPT-Dashboard-URL (z.B. wenn RAPT auf anderem VPS läuft).
# Leer lassen → EnvConfig leitet aus aktuellem Hostname ab.
RAPT_DASHBOARD_URL=

# ─── Docker Compose ─── (steuert Image-Pull + Port-Mappings)
DOCKERHUB_USERNAME=<dein-dockerhub-user>
WEB_ASSISTENT_PORT=8081
SUPABASE_PORT=54321
STUDIO_PORT=54323
POSTGRES_PORT=54322

# ─── Supabase Server-Secrets ─── (generieren: scripts/generate-supabase-secrets.sh --write)
POSTGRES_PASSWORD=<openssl rand -base64 32>
JWT_SECRET=<openssl rand -base64 64>
SECRET_KEY_BASE=<openssl rand -base64 64>
ANON_KEY=<HS256-JWT mit role=anon, signiert mit JWT_SECRET>
SERVICE_ROLE_KEY=<HS256-JWT mit role=service_role>
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=<openssl rand -base64 24>
PG_META_CRYPTO_KEY=<openssl rand -hex 32>

# Studio-Settings (kosmetisch)
DEFAULT_ORGANIZATION_NAME=Brewing
DEFAULT_PROJECT_NAME=aibrewgenius

# Server-seitig: wo Supabase nach außen erreichbar ist
SUPABASE_PUBLIC_URL=http://localhost:54321
SITE_URL=http://localhost:8081
ADDITIONAL_REDIRECT_URLS=
